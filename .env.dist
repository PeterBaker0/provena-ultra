# ============================================================================
# Provena v2 environment configuration
# Copy to .env and adjust. A single file feeds the API, worker (via
# @provena/config) and all four UIs (via Vite envDir, VITE_* vars only).
# ============================================================================

# ----------------------------- API / worker --------------------------------
NODE_ENV=development
API_PORT=8080
API_PUBLIC_URL=http://localhost:8080
CORS_ORIGINS=*

DATABASE_URL=postgres://provena:provena@localhost:5432/provena

# Keycloak (reused legacy deployment - realm issuer URL)
KEYCLOAK_ISSUER=http://localhost:8081/realms/provena
# Test-mode HS256 token secret - NEVER set in production
# AUTH_TEST_SHARED_SECRET=

# Realm preparation (pnpm keycloak:prepare-realm)
# KC_REALM_NAME=provena
# KC_ROOT_DOMAIN=localhost
# KC_DISPLAY_NAME=Provena
# KC_THEME_NAME=keycloak
# Dev users seeded into the realm import (provena-admin/admin with all roles,
# provena-user/user with general roles). SET false FOR PRODUCTION.
# KC_SEED_DEV_USERS=true

# Object storage (S3 + STS compatible; RustFS in the compose stack)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=provena-root
STORAGE_SECRET_KEY=provena-secret
STORAGE_BUCKET=provena-datasets
STORAGE_DATASET_PATH=datasets
STORAGE_STS_ROLE_ARN=arn:aws:iam::000000000000:role/provena-dataset-access
STORAGE_CREDENTIAL_DURATION_SECONDS=3600
STORAGE_FORCE_PATH_STYLE=true
# Optional web console template for the storage backend ({bucket}/{path}):
# STORAGE_CONSOLE_URL_TEMPLATE=http://localhost:9001/browser/{bucket}

# Handle (persistent identifier) minting
HANDLE_PREFIX=10378.1

# Email (SMTP - mailpit in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
EMAIL_FROM=provena@localhost
ACCESS_REQUEST_EMAIL_ADDRESS=admin@localhost

# Jobs - run worker inside the API process (set false + run @provena/worker
# separately to scale workers independently)
WORKER_EMBEDDED=true

# ------------------------------- Frontends ---------------------------------
# All legacy service endpoints map to base paths of the monolith API.
VITE_AUTH_API_ENDPOINT=http://localhost:8080/api/auth
VITE_REGISTRY_API_ENDPOINT=http://localhost:8080/api/registry
VITE_DATA_STORE_API_ENDPOINT=http://localhost:8080/api/data-store
VITE_PROV_API_ENDPOINT=http://localhost:8080/api/prov
VITE_SEARCH_API_ENDPOINT=http://localhost:8080/api/search
VITE_JOB_API_ENDPOINT=http://localhost:8080/api/job
VITE_WARMER_API_ENDPOINT=http://localhost:8080/api/warmer

# Keycloak (client ids match the reused legacy realm)
VITE_KEYCLOAK_AUTH_ENDPOINT=http://localhost:8081
VITE_KEYCLOAK_REALM=provena

# Cross-UI links (dev ports: landing 3001, registry 3002, data store 3003, prov 3004)
VITE_LANDING_PAGE_LINK=http://localhost:3001
VITE_REGISTRY_LINK=http://localhost:3002
VITE_DATA_STORE_LINK=http://localhost:3003
VITE_PROV_STORE_LINK=http://localhost:3004

# Misc UI config
VITE_THEME_ID=default
VITE_STAGE=DEV
VITE_DOCUMENTATION_BASE_LINK=https://docs.provena.io
VITE_CONTACT_US_LINK=https://docs.provena.io/contact
VITE_MONITORING_ENABLED=false
# VITE_SENTRY_DSN=
VITE_GIT_COMMIT_ID=dev
VITE_FEATURE_NUMBER=
