NODE_ENV=development
LOG_LEVEL=info
API_PORT=3000
WORKER_PORT=3001
CORS_ORIGINS=http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005

# PostgreSQL
DATABASE_URL=postgres://provena:provena@localhost:5432/provena
DATABASE_SSL=false

# Keycloak
KEYCLOAK_ISSUER=http://localhost:8080/realms/DEV
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/DEV/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=account
KEYCLOAK_CLIENT_ID=registry-api
KEYCLOAK_AUTH_ENDPOINT=http://localhost:8080

# Queue
PG_BOSS_SCHEMA=pgboss
PG_BOSS_POLL_INTERVAL_SECONDS=5

# Storage (S3 compatible: Ceph RGW preferred)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=provena
S3_SECRET_KEY=provena-secret
S3_BUCKET=provena-data
S3_FORCE_PATH_STYLE=true
STORAGE_PROVIDER=ceph-rgw

# Handle service compatibility
HANDLE_SERVICE_PREFIX=provena
HANDLE_SERVICE_BASE_URL=http://localhost:3000/handle

# SMTP / notifications
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@provena.local

# Frontend API endpoints (legacy-compatible env names)
VITE_AUTH_API_ENDPOINT=http://localhost:3000
VITE_DATA_STORE_API_ENDPOINT=http://localhost:3000
VITE_REGISTRY_API_ENDPOINT=http://localhost:3000
VITE_PROV_API_ENDPOINT=http://localhost:3000
VITE_SEARCH_API_ENDPOINT=http://localhost:3000
VITE_JOB_API_ENDPOINT=http://localhost:3000
VITE_WARMER_API_ENDPOINT=http://localhost:3000/warmer
VITE_KEYCLOAK_AUTH_ENDPOINT=http://localhost:8080
VITE_KEYCLOAK_REALM=DEV
VITE_STAGE=DEV
VITE_THEME_ID=default
VITE_SENTRY_DSN=
VITE_GIT_COMMIT_ID=local-dev
VITE_MONITORING_ENABLED=
VITE_FEATURE_NUMBER=

# Frontend link vars
VITE_LANDING_PAGE_LINK=http://localhost:3005
VITE_DATA_STORE_LINK=http://localhost:3003
VITE_PROV_STORE_LINK=http://localhost:3004
VITE_REGISTRY_LINK=http://localhost:3002
VITE_DOCUMENTATION_BASE_LINK=https://example.org/docs
VITE_CONTACT_US_LINK=https://example.org/contact
