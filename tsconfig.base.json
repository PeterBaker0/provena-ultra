{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@provena/config": ["packages/config/src/index.ts"],
      "@provena/contracts": ["packages/contracts/src/index.ts"],
      "@provena/observability": ["packages/observability/src/index.ts"],
      "@provena/db": ["packages/db/src/index.ts"],
      "@provena/auth": ["packages/auth/src/index.ts"],
      "@provena/queue": ["packages/queue/src/index.ts"],
      "@provena/storage": ["packages/storage/src/index.ts"],
      "@provena/search": ["packages/search/src/index.ts"],
      "@provena/ui-shared": ["packages/ui-shared/src/index.ts"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  }
}
